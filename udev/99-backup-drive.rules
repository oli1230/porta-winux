# This rule fires on device *arrival*, not on mount completion — udisks2
# (the same thing backing Dolphin/GNOME Files auto-mount) may take a moment
# longer to finish mounting to /run/media/$USER/<label>. That's fine:
# drive_handler.sh calls scripts/check_drive_mounted.sh, which polls for the
# mount (and, if you set drive.expected_uuid in manifest.yaml, verifies it's
# actually the right physical drive) before doing anything else.

SUBSYSTEM=="block", ENV{ID_FS_UUID}=="REPLACE-WITH-YOUR-UUID", ACTION=="add", \
    TAG+="systemd", ENV{SYSTEMD_WANTS}+="borg-drive-handler@%k.service"
