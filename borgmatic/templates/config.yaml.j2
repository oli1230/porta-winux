# AUTO-GENERATED by scripts/render_borgmatic_config.py — do not hand-edit.
# Source of truth: manifest/manifest.yaml (host: {{ host }})
# Regenerated on every drive-attach by scripts/drive_handler.sh

source_directories:
{% for p in paths %}
  - {{ p }}
{% endfor %}

repositories:
  - path: {{ repo_path }}
    label: {{ host }}

exclude_patterns:
{% for e in excludes %}
  - "{{ e }}"
{% endfor %}

keep_daily: {{ retention.keep_daily }}
keep_weekly: {{ retention.keep_weekly }}
keep_monthly: {{ retention.keep_monthly }}

checks:
  - name: repository
  - name: archives
    frequency: 2 weeks

before_backup:
  - 'echo "[$(date -Iseconds)] backup starting for {{ host }}" >> {{ log_path }}'

after_backup:
  - 'echo "[$(date -Iseconds)] backup finished for {{ host }}" >> {{ log_path }}'

on_error:
  - 'echo "[$(date -Iseconds)] BACKUP FAILED for {{ host }}" >> {{ log_path }}'
